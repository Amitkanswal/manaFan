{
  "name": "mangafan",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "serve:dev": "npm run db:setup && npm run dev",
    "serve:prod": "npm run db:setup && npm run build && npm run start",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:reset": "rm -f prisma/dev.db && touch prisma/dev.db && sqlite3 prisma/dev.db < prisma/migrations/20260112052915_init/migration.sql && prisma generate",
    "db:setup": "test -s prisma/dev.db || npm run db:reset",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@contentstack/delivery-sdk": "^4.10.5",
    "@contentstack/personalize-edge-sdk": "^1.0.19",
    "@prisma/adapter-better-sqlite3": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.468.0",
    "next": "^14.2.21",
    "nodemailer": "^7.0.12",
    "prisma": "^7.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^7.0.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.21",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
